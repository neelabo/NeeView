<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="clr-namespace:NeeView">

    <!-- Material design icons by Google -->
    <!-- http://www.google.com/design/spec/style/icons.html#icons-system-icons -->

    <DrawingImage x:Key="ic_desktop_windows_24px">
        <DrawingImage.Drawing>
            <GeometryDrawing Brush="{DynamicResource Panel.Foreground}" Pen="{x:Null}" Geometry="{StaticResource g_desktop_windows_24px}" />
        </DrawingImage.Drawing>
    </DrawingImage>

    <DrawingImage x:Key="ic_desktop_windows_24px_t">
        <DrawingImage.Drawing>
            <GeometryDrawing Brush="{DynamicResource Panel.Foreground}" Pen="{x:Null}" Geometry="{StaticResource g_desktop_windows_24px_t}" />
        </DrawingImage.Drawing>
    </DrawingImage>

    <DrawingImage x:Key="ic_search_24px">
        <DrawingImage.Drawing>
            <GeometryDrawing Brush="{DynamicResource Panel.Foreground}" Pen="{x:Null}" Geometry="{StaticResource g_search_24px}" />
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- https://www.onlinewebfonts.com/icon/35498 -->
    <DrawingImage x:Key="ic_lightning">
        <DrawingImage.Drawing>
            <GeometryDrawing Brush="{DynamicResource Panel.Foreground}" Pen="{x:Null}" Geometry="{StaticResource g_lightning}" />
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- https://www.onlinewebfonts.com/icon/97722 -->
    <DrawingImage x:Key="ic_bookshelf">
        <DrawingImage.Drawing>
            <GeometryDrawing Brush="{DynamicResource Panel.Foreground}" Pen="{x:Null}" Geometry="{StaticResource g_bookshelf}" />
        </DrawingImage.Drawing>
    </DrawingImage>

    <!-- https://www.onlinewebfonts.com/icon/89022 -->
    <DrawingImage x:Key="ic_noentry">
        <DrawingImage.Drawing>
            <GeometryDrawing Brush="{DynamicResource Thumbnail.Foreground}" Pen="{x:Null}" Geometry="{StaticResource g_noentry}"/>
        </DrawingImage.Drawing>
    </DrawingImage>

    <DrawingImage x:Key="ic_folder_up">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="Transparent">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="-12,-12,48,48" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="{DynamicResource Thumbnail.Foreground}" Pen="{x:Null}" Geometry="{StaticResource g_arrow_up_24px}" />
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>


    <!-- NeeView original -->
    <DrawingImage x:Key="thumbnail_default">
        <DrawingImage.Drawing>
            <GeometryDrawing Brush="{DynamicResource Thumbnail.Background}" Pen="{x:Null}">
                <GeometryDrawing.Geometry>
                    <PathGeometry FillRule="Nonzero" Figures="M0,0 192,0 192,256 0,256 Z" />
                </GeometryDrawing.Geometry>
            </GeometryDrawing>
        </DrawingImage.Drawing>
    </DrawingImage>

    <DrawingImage x:Key="ic_playlist">
        <DrawingImage.Drawing>
            <GeometryDrawing>
                <GeometryDrawing.Pen>
                    <Pen Brush="{DynamicResource Panel.Foreground}" Thickness="1.25"></Pen>
                </GeometryDrawing.Pen>
                <GeometryDrawing.Geometry>
                    <PathGeometry FillRule="Nonzero" Figures="M0,0 L5,0 0,5Z  M6,3 16,3 M0,8 16,8 M0,13 16,13" />
                </GeometryDrawing.Geometry>
            </GeometryDrawing>
        </DrawingImage.Drawing>
    </DrawingImage>

    <DrawingImage x:Key="ic_javascript_24px">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="Transparent" Geometry="{StaticResource g_rect24x24}" />
                <GeometryDrawing Brush="{DynamicResource Panel.Foreground}" Pen="{x:Null}" Geometry="{StaticResource g_javascript_24px}" />
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

</ResourceDictionary>
