<UserControl x:Class="NeeView.Windows.Property.PropertyControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NeeView.Windows.Property"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             d:DesignHeight="30" d:DesignWidth="300">

    <UserControl.Resources>
        <local:PropertyValueTemplateSelector x:Key="PropertyValueTemplateSelector"/>

        <Style x:Key="ClickBorderStyle" TargetType="Border">
            <EventSetter Event="MouseLeftButtonDown" Handler="Root_MouseLeftButtonDown"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Control.MouseOver.Background}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <local:PropertyValueToClickStyleConverter x:Key="PropertyValueToClickStyleConverter" ClickStyle="{StaticResource ClickBorderStyle}"/>

        <Style x:Key="NoteTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Control.GrayText}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Style.Triggers>
                <Trigger Property="Text" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderStackPanelStyle" TargetType="StackPanel">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="MinWidth" Value="50"/>
        </Style>

        <Style x:Key="HeaderTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Text" Value="{Binding Header, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <DataTemplate x:Key="ValueHeaderTemplate">
            <StackPanel Style="{StaticResource HeaderStackPanelStyle}">
                <TextBlock Style="{StaticResource HeaderTextBlockStyle}" />
                <TextBlock Style="{StaticResource NoteTextBlockStyle}" Text="{Binding Tips, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="ToolTipValueHeaderTemplate">
            <StackPanel Style="{StaticResource HeaderStackPanelStyle}">
                <TextBlock Style="{StaticResource HeaderTextBlockStyle}" ToolTip="{Binding Tips, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </StackPanel>
        </DataTemplate>

        <Style x:Key="ValueHeaderStyle" TargetType="ContentControl">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="ContentTemplate" Value="{StaticResource ValueHeaderTemplate}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding UseToolTip, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                    <Setter Property="ContentTemplate" Value="{StaticResource ToolTipValueHeaderTemplate}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Border x:Name="Root" Style="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource PropertyValueToClickStyleConverter}}">
        <DockPanel Margin="5,5,0,5">
            <ContentControl x:Name="ValueUI" DockPanel.Dock="Right" UseLayoutRounding="True" Grid.Column="1" VerticalAlignment="Center" Margin="5,0" IsTabStop="False" 
                Content="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}" ContentTemplateSelector="{StaticResource PropertyValueTemplateSelector}" />
            <ContentControl x:Name="ValueHeader" Style="{StaticResource ValueHeaderStyle}" />
        </DockPanel>
    </Border>

</UserControl>
