<UserControl x:Class="NeeView.Windows.Controls.ColorizeControlPointEdit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NeeView.Windows.Controls"
             xmlns:nwc="clr-namespace:NeeView.Windows.Controls"
             xmlns:osc="clr-namespace:OpenSourceControls"
             xmlns:properties="clr-namespace:NeeView.Properties"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300">
    <StackPanel x:Name="Root" >
        <DockPanel Margin="0,1" KeyboardNavigation.TabNavigation="Local">
            <TextBlock Width="64" Text="{properties:TextBinding ColorizeControlPoint.Color}" VerticalAlignment="Center" />
            <nwc:EnterTriggerTextBox DockPanel.Dock="Right" Text="{Binding Color}" MinWidth="100" BorderThickness="1" VerticalContentAlignment="Center" TabIndex="2"/>
            <osc:ComboColorPicker SelectedColor="{Binding Color, Mode=TwoWay}" TabIndex="1"/>
        </DockPanel>
        <DockPanel Margin="0,1" KeyboardNavigation.TabNavigation="Local">
            <TextBlock Width="64" Text="{properties:TextBinding ColorizeControlPoint.Strength}" VerticalAlignment="Center" />
            <nwc:EnterTriggerTextBox DockPanel.Dock="Right" Width="70" Text="{Binding Strength}" Slider="{Binding ElementName=SliderS}" />
            <Slider x:Name="SliderS" Value="{Binding Strength}" Minimum="0.0" Maximum="10.0" TickFrequency="1" IsSnapToTickEnabled="True" Margin="5,0" TabIndex="1" />
        </DockPanel>
    </StackPanel>
</UserControl>
