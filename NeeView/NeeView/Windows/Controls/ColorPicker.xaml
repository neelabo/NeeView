<UserControl x:Class="NeeView.Windows.Controls.ColorPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NeeView.Windows.Controls"
             xmlns:osc="clr-namespace:OpenSourceControls"
             xmlns:nwc="clr-namespace:NeeView.Windows.Controls"
             xmlns:nv="clr-namespace:NeeView"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="300">

    <UserControl.Resources>
        <nv:ColorModeToVisibilityConverter x:Key="ColorModeToVisibilityConverter"/>
        <nv:ColorToStringConverter x:Key="ColorToStringConverter" />
    </UserControl.Resources>

    <Grid x:Name="Root" VerticalAlignment="Center" >

        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="100" />
        </Grid.ColumnDefinitions>
        <Button x:Name="ColorButton" Grid.Column="0" Style="{StaticResource ColorButton}"  Click="ColorButton_Click" MinHeight="20" BorderThickness="1" >
            <Button.Background>
                <SolidColorBrush Color="{Binding Color}" d:Color="#8000" />
            </Button.Background>
        </Button>
        <nwc:EnterTriggerTextBox Grid.Column="2" Text="{Binding Color, Converter={StaticResource ColorToStringConverter}}" />

        <Popup x:Name="EditPopup" Placement="Bottom" PlacementTarget="{Binding ElementName=ColorButton}" StaysOpen="False" MinWidth="300"
                Opened="EditPopup_Opened" Closed="EditPopup_Closed"
                PreviewMouseDown="EditPopup_PreviewMouseDown"
                PreviewMouseUp="EditPopup_PreviewMouseUp"
                MouseMove="EditPopup_MouseMove"
                MouseWheel="EditPopup_MouseWheel"
                KeyDown="EditPopup_KeyDown"
                PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}"
                AllowsTransparency="True">
            <Border x:Name="PopupRoot" TextBlock.Foreground="{DynamicResource Menu.Foreground}" Background="{DynamicResource Menu.Background}" BorderBrush="{DynamicResource Menu.Border}" BorderThickness="1" Margin="5">
                <Border.Effect>
                    <DropShadowEffect Opacity="0.5" ShadowDepth="2" />
                </Border.Effect>

                <StackPanel Margin="10">

                    <osc:ComboColorPicker x:Name="ColorComboBox" SelectedColor="{Binding Color, Mode=TwoWay}" UseCustomColor="True"
                            DefaultColor="{Binding RelativeSource={RelativeSource AncestorType=local:ColorPicker}, Path=DefaultColor}"  TabIndex="1"/>

                    <Separator/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="ColorModeComboBox" Grid.Column="0" ItemsSource="{Binding ColorModeList}" SelectedItem="{Binding RelativeSource={RelativeSource AncestorType=local:ColorPicker}, Path=ColorMode}" HorizontalAlignment="Left"/>
                        <Button x:Name="DropperButton" Grid.Column="1" Style="{StaticResource IconButton}" HorizontalAlignment="Right"
                                Click="DropperButton_Click">
                            <Image Style="{StaticResource ColorizeIconImageStyle}"/>
                        </Button>
                    </Grid>

                    <StackPanel Margin="8,0,0,0">

                        <StackPanel Visibility="{Binding RelativeSource={RelativeSource AncestorType=local:ColorPicker}, Path=ColorMode, Converter={StaticResource ColorModeToVisibilityConverter}, ConverterParameter={x:Static nv:ColorMode.RGB}}">
                            <DockPanel Margin="0,0,0,5" KeyboardNavigation.TabNavigation="Local">
                                <TextBlock Width="16" Text="R" />
                                <nwc:EnterTriggerTextBox DockPanel.Dock="Right"
                                         Width="70"
                                         Text="{Binding R}" Slider="{Binding ElementName=SliderR}" />
                                <Slider x:Name="SliderR" Value="{Binding R}" Minimum="0" Maximum="255" TickFrequency="1" Margin="5,0" TabIndex="1" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,5" KeyboardNavigation.TabNavigation="Local">
                                <TextBlock Width="16" Text="G" />
                                <nwc:EnterTriggerTextBox DockPanel.Dock="Right"
                                         Width="70"
                                         Text="{Binding G}" Slider="{Binding ElementName=SliderG}" />
                                <Slider x:Name="SliderG" Value="{Binding G}" Minimum="0" Maximum="255" TickFrequency="1" Margin="5,0" TabIndex="1" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,5" KeyboardNavigation.TabNavigation="Local">
                                <TextBlock Width="16" Text="B" />
                                <nwc:EnterTriggerTextBox DockPanel.Dock="Right"
                                         Width="70"
                                         Text="{Binding B}" Slider="{Binding ElementName=SliderB}" />
                                <Slider x:Name="SliderB" Value="{Binding B}" Minimum="0" Maximum="255" TickFrequency="1"  Margin="5,0" TabIndex="1"/>
                            </DockPanel>
                            <DockPanel Margin="0,0,0,5" KeyboardNavigation.TabNavigation="Local">
                                <TextBlock Width="16" Text="A" />
                                <nwc:EnterTriggerTextBox DockPanel.Dock="Right"
                                         Width="70"
                                         Text="{Binding A}" Slider="{Binding ElementName=SliderA}" />
                                <Slider x:Name="SliderA" Value="{Binding A}" Minimum="0" Maximum="255" TickFrequency="1"  Margin="5,0" TabIndex="1"/>
                            </DockPanel>
                        </StackPanel>

                        <StackPanel Visibility="{Binding RelativeSource={RelativeSource AncestorType=local:ColorPicker}, Path=ColorMode, Converter={StaticResource ColorModeToVisibilityConverter}, ConverterParameter={x:Static nv:ColorMode.HSV}}">
                            <DockPanel Margin="0,0,0,5" KeyboardNavigation.TabNavigation="Local">
                                <TextBlock Width="16" Text="H" />
                                <nwc:EnterTriggerTextBox DockPanel.Dock="Right"
                                         Width="70"
                                         Text="{Binding H}" Slider="{Binding ElementName=SliderH}" />
                                <Slider x:Name="SliderH" Value="{Binding H}" Minimum="0" Maximum="360" TickFrequency="1" Margin="5,0" TabIndex="1"/>
                            </DockPanel>
                            <DockPanel Margin="0,0,0,5" KeyboardNavigation.TabNavigation="Local">
                                <TextBlock Width="16" Text="S" />
                                <nwc:EnterTriggerTextBox DockPanel.Dock="Right"
                                         Width="70"
                                         Text="{Binding S, StringFormat={}{0:0.00}}" Slider="{Binding ElementName=SliderS}" />
                                <Slider x:Name="SliderS" Value="{Binding S}" Minimum="0" Maximum="1" TickFrequency="0.01" Margin="5,0" TabIndex="1"/>
                            </DockPanel>
                            <DockPanel Margin="0,0,0,5" KeyboardNavigation.TabNavigation="Local">
                                <TextBlock Width="16" Text="V" />
                                <nwc:EnterTriggerTextBox DockPanel.Dock="Right"
                                         Width="70"
                                         Text="{Binding V, StringFormat={}{0:0.00}}" Slider="{Binding ElementName=SliderV}" />
                                <Slider x:Name="SliderV" Value="{Binding V}" Minimum="0" Maximum="1" TickFrequency="0.01" Margin="5,0" TabIndex="1"/>
                            </DockPanel>
                            <DockPanel Margin="0,0,0,5" KeyboardNavigation.TabNavigation="Local">
                                <TextBlock Width="16" Text="A" />
                                <nwc:EnterTriggerTextBox DockPanel.Dock="Right"
                                         Width="70"
                                         Text="{Binding HsvA, StringFormat={}{0:0.00}}" Slider="{Binding ElementName=SliderHsvA}" />
                                <Slider x:Name="SliderHsvA" Value="{Binding HsvA}" Minimum="0" Maximum="1" TickFrequency="0.01" Margin="5,0" TabIndex="1"/>
                            </DockPanel>
                        </StackPanel>

                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
