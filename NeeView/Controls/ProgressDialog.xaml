<Window x:Class="NeeView.ProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NeeView"
        xmlns:properties="clr-namespace:NeeView.Properties"
        mc:Ignorable="d"
        Style="{StaticResource ChromeNoneStyle}" 
        UseLayoutRounding="True"
        ShowInTaskbar="False"
        Title="ProgressDialog" SizeToContent="Height" Width="480" ResizeMode="NoResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <local:StringNullOrWhiteSpaceToVisibilityConverter x:Key="StringNullOrWhiteSpaceToVisibilityHiddenConverter" True="Collapsed" False="Visible" />
    </Window.Resources>

    <Grid>
        <StackPanel Margin="20,20,10,20">
            <DockPanel Margin="0,0,10,0">
                <local:ProgressRing x:Name="ProgressRing" DockPanel.Dock="Left" Margin="20,0,20,0" VerticalAlignment="Center"
                    d:Visibility="Visible"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="CaptionTextBlock" TextWrapping="Wrap" Text="{Binding Caption}" FontSize="{DynamicResource SystemFontSizeHuge}" FontWeight="Normal"
                        Visibility="{Binding Caption, Converter={StaticResource StringNullOrWhiteSpaceToVisibilityHiddenConverter}}"
                        d:Text="Caption" d:Visibility="Collapsed" />
                    <TextBlock x:Name="MessageTextBlock" TextWrapping="Wrap" Text="{Binding Message}" Margin="0,10"
                        Visibility="{Binding Message, Converter={StaticResource StringNullOrWhiteSpaceToVisibilityHiddenConverter}}"
                        d:Text="Message..." d:Visibility="Visible" />
                    <ProgressBar x:Name="ProgressBar" Value="{Binding ProgressValue}" Minimum="0.0" Maximum="1.0" Margin="0,10,0,20"
                        Foreground="{DynamicResource Control.Accent}" Background="{DynamicResource Slider.Background}" BorderThickness="0" Height="4"
                        d:Visibility="Collapsed" d:Value="0.5" />
                </StackPanel>
            </DockPanel>

            <Button x:Name="CancelButton" DockPanel.Dock="Bottom" Style="{StaticResource NVDialogButton}" HorizontalAlignment="Right" Margin="0,5,0,-10" Content="{properties:TextBinding Word.Cancel}" Click="CancelButton_Click"
                Visibility="{Binding CanCancel, Converter={StaticResource BooleanToVisibilityConverter}}"
                d:Visibility="Visible" />
        </StackPanel>
    </Grid>
</Window>
