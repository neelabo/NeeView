<Window x:Class="NeeView.ProgressMessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NeeView"
        xmlns:properties="clr-namespace:NeeView.Properties"
        mc:Ignorable="d"
        Style="{StaticResource ChromeDialogStyle}" 
        UseLayoutRounding="True"
        WindowStyle="None"
        ShowInTaskbar="False"
        Title="ProgressMessageDialog" SizeToContent="Height" Width="480" ResizeMode="NoResize">
    <Window.Resources>
        <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityHiddenConverter" False="Hidden" />
    </Window.Resources>
    <Grid>
        <DockPanel Margin="10" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <Button x:Name="CancelButton" DockPanel.Dock="Bottom" Style="{StaticResource NVDialogButton}" HorizontalAlignment="Right" Margin="0,0,0,0" Content="{properties:TextBinding Word.Cancel}" Click="CancelButton_Click"
                    Visibility="{Binding CanCancel, Converter={StaticResource BooleanToVisibilityHiddenConverter}}"/>
            <DockPanel Margin="0,10" MinHeight="40">
                <local:ProgressRing DockPanel.Dock="Left" Margin="10,0" Radius="8" VerticalAlignment="Center"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="MessageTextBlock" TextWrapping="Wrap" Text="{Binding Message}" />
                    <TextBlock x:Name="CancelTextBlock" TextWrapping="Wrap" Text="{properties:TextBinding Word.Canceling}" Visibility="{Binding IsCanceled, Converter={StaticResource BooleanToVisibilityConverter}}"  />
                </StackPanel>
            </DockPanel>
        </DockPanel>
    </Grid>
</Window>
