<Window x:Class="NeeView.PropertyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NeeView"
        xmlns:nwc="clr-namespace:NeeView.Windows.Controls"
        xmlns:nwp="clr-namespace:NeeView.Windows.Property"
        xmlns:properties="clr-namespace:NeeView.Properties"
        mc:Ignorable="d"
        Style="{StaticResource ChromeDialogStyle}"
        Title="{properties:TextBinding Word.Property}"
        Width="512" SizeToContent="Height" >

    <Window.Resources>
        <ResourceDictionary>
            <Style x:Key="ButtonStyle" TargetType="Button" BasedOn="{StaticResource NVDialogButton}" />
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel Margin="5">

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
            <Button x:Name="OKButton" Style="{StaticResource ButtonStyle}" Content="{properties:TextBinding Word.OK}" Click="OKButton_Click" />
            <Button x:Name="CancelButton" Style="{StaticResource ButtonStyle}" Content="{properties:TextBinding Word.Cancel}" Click="CancelButton_Click" />
        </StackPanel>

        <ScrollViewer Style="{StaticResource NVScrollViewer}">
        <nwp:PropertyInspector x:Name="GeneralInspector" Margin="10"
            Document="{Binding RelativeSource={RelativeSource AncestorType=local:PropertyDialog}, Path=Document}"
            KeyboardNavigation.TabNavigation="Local"
            IsStretch="True"
            IsResetButtonVisible="False"
            ColumnRate="{Binding RelativeSource={RelativeSource AncestorType=local:PropertyDialog}, Path=ColumnRate}"/>
        </ScrollViewer>

    </DockPanel>
</Window>
